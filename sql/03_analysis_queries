--13. Joins Based Personal Identification Analysis

SELECT
    [PIN_Code] AS pin_id,

    COUNT(*) AS total_transactions,

    ROUND(
        SUM(CAST([Transaction_Amount] AS FLOAT)),
        2
    ) AS total_spent

FROM dbo.transaction_raw
GROUP BY [PIN_Code]
ORDER BY total_spent DESC;
GO

--14. Transaction By Network Slice ID

SELECT
    Network_Slice_ID,
    COUNT(*) AS total_transactions,
    ROUND(SUM(transaction_amount), 2) AS total_revenue,
    ROUND(AVG(transaction_amount), 2) AS avg_transaction_amount
FROM dbo.transaction_raw
GROUP BY Network_Slice_ID
ORDER BY total_revenue DESC;
GO

